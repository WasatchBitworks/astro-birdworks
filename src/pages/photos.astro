---
import Base from "../layouts/Base.astro";
import DataUpdated from "../components/DataUpdated.astro";
import PhotoCard from "../components/PhotoCard.astro";
import { getBirdsData } from "../lib/birds";

const birds = await getBirdsData();

const uniqueSpeciesCount = new Set(
  birds.photos.map((p) => p.species?.common_name).filter(Boolean),
).size;

// Random order per build (Fisher-Yates), matching birdworks' shuffle filter
const shuffled = [...birds.photos];
for (let i = shuffled.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [shuffled[i], shuffled[j]] = [shuffled[j]!, shuffled[i]!];
}
---

<Base
  title="Photo Gallery"
  description="Bird photography from the Wasatch Front, Utah. Beautiful images of local bird species."
>
  <!-- Hero Section -->
  <section class="hero-observatory relative py-12 md:py-16">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-bold mb-4 md:mb-6 tracking-tight leading-tight">
        Photo Gallery
      </h1>
      <p class="text-base sm:text-xl md:text-2xl mb-3 md:mb-4 max-w-3xl mx-auto text-gray-200 px-2">
        Bird photography from the Wasatch Front, Utah
      </p>
      <p class="text-sm md:text-base text-green-200 italic">Photography by Zachary Kane</p>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-8 bg-white border-b">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-green-800">{birds.photos.length}</div>
          <div class="text-sm text-gray-600">Total Photos</div>
        </div>
        <div class="hidden sm:block w-px h-12 bg-gray-300"></div>
        <div>
          <div class="text-3xl font-bold text-orange-800">{uniqueSpeciesCount}</div>
          <div class="text-sm text-gray-600">Species</div>
        </div>
      </div>
    </div>
  </section>

  {birds.photos.length > 0 ? (
    <section class="py-12 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4">
        <div class="mb-8">
          <p class="eyebrow">Gallery</p>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-2">Featured Photos</h2>
          <p class="text-gray-600">Bird photography from the Wasatch Front</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {shuffled.map((photo) => <PhotoCard photo={photo} />)}
        </div>
      </div>
    </section>
  ) : (
    <section class="py-16 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <svg class="w-20 h-20 mx-auto mb-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
          ></path>
        </svg>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">No Photos Yet</h2>
        <p class="text-gray-600 mb-6">
          Our photo gallery is being built. Check back soon for beautiful bird photography from the Wasatch Front!
        </p>
        <a href="/" class="btn-primary px-6 py-3 rounded-lg inline-block">Back to Home</a>
      </div>
    </section>
  )}

  <DataUpdated generatedAt={birds.generatedAt} label="Gallery updated" />
</Base>
