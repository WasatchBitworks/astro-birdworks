---
import Base from "../../layouts/Base.astro";
import DataUpdated from "../../components/DataUpdated.astro";
import SpeciesCard from "../../components/SpeciesCard.astro";
import { getBirdsData } from "../../lib/birds";
import { findPhotoBySpecies } from "../../lib/photos";

const birds = await getBirdsData();
const totalDetections = birds.species.reduce((sum, s) => sum + (s.detection_count ?? 0), 0);
---

<Base
  title="Species Index"
  description="Complete list of bird species detected by our BirdNET-Pi system on the Wasatch Front, Utah."
>
  <!-- Page Header -->
  <section class="hero-observatory py-12">
    <div class="max-w-7xl mx-auto px-4">
      <p class="eyebrow">Field Guide</p>
      <h1 class="text-4xl font-bold mb-4">Species Index</h1>
      <p class="text-xl text-green-200">Click on a species card for more photos and audio recordings</p>
    </div>
  </section>

  <!-- Species Grid -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      {birds.species.length > 0 ? (
        <>
          <!-- Photography Note -->
          <div class="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6 rounded-r-lg">
            <p class="text-sm text-gray-700">
              <strong class="text-blue-900">Photography:</strong> All bird photos by Zachary Kane.
              Species without photos are actively being photographed as they visit.
            </p>
          </div>

          <!-- Summary Stats -->
          <div class="bg-white rounded-lg shadow-md p-6 mb-8">
            <div class="grid md:grid-cols-3 gap-6 text-center">
              <div>
                <div class="text-3xl font-bold text-blue-700">{birds.species.length}</div>
                <div class="text-gray-600">Total Species</div>
              </div>
              <div>
                <div class="text-3xl font-bold text-green-700">{totalDetections}</div>
                <div class="text-gray-600">Total Detections</div>
              </div>
              <div>
                <div class="text-3xl font-bold text-earth-brown">
                  {birds.species[0]?.common_name ?? "—"}
                </div>
                <div class="text-gray-600">Most Detected</div>
              </div>
            </div>
          </div>

          <!-- Species Cards Grid -->
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {birds.species.map((species) => (
              <SpeciesCard species={species} photo={findPhotoBySpecies(birds.photos, species.common_name)} />
            ))}
          </div>
        </>
      ) : (
        <!-- Empty State -->
        <div class="bg-white rounded-lg shadow-lg p-16 text-center">
          <svg class="w-24 h-24 mx-auto mb-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <h2 class="text-2xl font-bold text-gray-800 mb-3">No Species Detected Yet</h2>
          <p class="text-gray-600 mb-6 max-w-md mx-auto">
            The BirdNET-Pi system is actively monitoring. Once birds are detected, they'll appear here!
          </p>
          <a href="/live" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
            View Live Feed
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Species Info -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4">About Our Species Data</h2>
      <p class="text-gray-700 leading-relaxed mb-6">
        Our BirdNET-Pi system uses the BirdNET 6K Global Model, which can identify over 6,000 bird species worldwide.
        The species shown here are those that have been detected in our monitoring area on the Wasatch Front, Utah.
      </p>
      <p class="text-gray-600 text-sm">
        Detection counts include all confidence levels. Higher detection counts generally indicate more common species in the area.
      </p>
    </div>
  </section>

  <DataUpdated generatedAt={birds.generatedAt} />
</Base>
