---
import Base from "../../layouts/Base.astro";
import PhotoViewer from "../../components/species/PhotoViewer.astro";
import PresenceGrid from "../../components/species/PresenceGrid.astro";
import HourlyPatterns from "../../components/species/HourlyPatterns.astro";
import AudioSections from "../../components/species/AudioSections.astro";
import { getBirdsData } from "../../lib/birds";
import { toMountainDate, toMountainTime, toMountainTimeShort } from "../../lib/datetime";
import { filterPhotosBySpecies } from "../../lib/photos";
import { slugify } from "../../lib/slug";

export async function getStaticPaths() {
  const birds = await getBirdsData();
  return birds.species.map((species) => ({
    params: { slug: slugify(species.common_name) },
    props: { species },
  }));
}

const { species } = Astro.props;
const slug = Astro.params.slug;
const birds = await getBirdsData();
const speciesPhotos = filterPhotosBySpecies(birds.photos, species.common_name);
---

<Base
  title={species.common_name}
  description={`${species.common_name} (${species.scientific_name}) detections and photos from the Wasatch Front, Utah. ${species.detection_count} detections recorded.`}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Back Links -->
    <div class="mb-6 flex flex-wrap gap-4">
      <a href="/species/" class="text-leaf-green hover:text-forest-green transition inline-flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to All Species
      </a>
      <a href="/photos/" class="text-leaf-green hover:text-forest-green transition inline-flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Back to Photos
      </a>
    </div>

    <!-- Species Header -->
    <section class="mb-8">
      <h1 class="text-4xl font-bold text-forest-green mb-2">{species.common_name}</h1>
      <p class="text-xl italic text-gray-600">{species.scientific_name}</p>
    </section>

    <!-- Detection Stats Cards -->
    <section class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-lg shadow-md p-6">
        <div class="text-3xl font-bold text-forest-green mb-1">{species.detection_count}</div>
        <div class="text-sm text-gray-600">Total Detections</div>
      </div>
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg shadow-md p-6">
        <div class="text-3xl font-bold text-sky-blue mb-1">{Math.round(species.max_confidence * 100)}%</div>
        <div class="text-sm text-gray-600">Best Confidence</div>
      </div>
      <div class="bg-gradient-to-br from-yellow-50 to-yellow-100 rounded-lg shadow-md p-6">
        <div class="text-3xl font-bold text-earth-brown mb-1">{Math.round(species.avg_confidence * 100)}%</div>
        <div class="text-sm text-gray-600">Avg Confidence</div>
      </div>
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg shadow-md p-6">
        <div class="text-2xl font-bold text-gray-900 mb-1">{toMountainDate(species.last_seen)}</div>
        <div class="text-lg font-semibold text-gray-900 mb-2">{toMountainTimeShort(species.last_seen)}</div>
        <div class="text-sm text-gray-600">Last Seen</div>
      </div>
    </section>

    <!-- Photo Viewer / Empty State -->
    {speciesPhotos.length > 0 ? (
      <PhotoViewer photos={speciesPhotos} speciesName={species.common_name} />
    ) : (
      <section class="mb-8">
        <div class="bg-gray-50 rounded-lg p-12 text-center">
          <svg class="w-16 h-16 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          <p class="text-lg font-semibold text-gray-700 mb-2">No photos have been added for this species yet.</p>
          <p class="text-gray-600">Still trying to photograph this bird!</p>
        </div>
      </section>
    )}

    <PresenceGrid speciesSlug={slug} />

    <HourlyPatterns speciesSlug={slug} />

    <AudioSections speciesSlug={slug} />

    <!-- Data timestamp footer -->
    <footer class="text-center py-4 text-sm text-gray-500 border-t border-gray-200">
      <p>Data updated: {toMountainTime(birds.generatedAt)}</p>
    </footer>
  </div>
</Base>
