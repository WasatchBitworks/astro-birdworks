---
import Base from "../layouts/Base.astro";
import DataUpdated from "../components/DataUpdated.astro";
import LiveFeed from "../components/live/LiveFeed.astro";
import { getBirdsData } from "../lib/birds";
import { toMountainDate, toMountainTime } from "../lib/datetime";

const birds = await getBirdsData();
---

<Base
  title="Detections Today"
  description="Today's bird detections from the Wasatch Front. See all birds identified by our BirdNET-Pi system."
>
  <!-- Page Header -->
  <section class="hero-observatory py-12">
    <div class="max-w-7xl mx-auto px-4">
      <p class="eyebrow">Live from the Station</p>
      <h1 class="text-4xl font-bold mb-4">Detections Today</h1>
      <p class="text-lg text-green-200">All birds identified on {toMountainDate(birds.todayDate)}</p>
    </div>
  </section>

  <!-- Live Feed -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <!-- Live Refresh Controls (static shell, always visible) -->
      <div class="bg-white rounded-lg shadow-md p-4 mb-6" id="liveRefreshControls">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-3">
          <div class="flex items-center gap-4 flex-wrap">
            <button
              id="refreshBtn"
              class="btn-primary px-4 py-2 rounded-lg text-sm font-semibold transition hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              <span id="refreshBtnText">Refresh Now</span>
            </button>

            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="autoRefreshToggle" class="w-4 h-4 text-green-600 rounded" />
              <span class="text-sm text-gray-700">Auto-refresh (5 min)</span>
            </label>
          </div>

          <div class="flex items-center gap-4 text-sm">
            <div id="refreshStatus" class="text-gray-600">
              <span id="statusText">Ready</span>
            </div>
            <div id="lastUpdated" class="text-gray-500">
              Last updated: <span id="lastUpdatedTime">{toMountainTime(birds.generatedAt)} MT</span>
            </div>
          </div>
        </div>
        <p class="text-sm text-gray-600 italic">
          Note: This page loads fresh data on every visit. Live-fetched updates between visits are transient; the refresh button and auto-refresh pull the latest detections on demand.
        </p>
      </div>

      <!-- Fresh data per request via server island -->
      <LiveFeed server:defer>
        <div slot="fallback" id="liveFallback">
          <div class="grid md:grid-cols-4 gap-4 mb-8">
            {[1, 2, 3, 4].map(() => (
              <div class="bg-white rounded-lg shadow p-4 text-center animate-pulse">
                <div class="h-8 bg-gray-200 rounded mb-2 mx-auto w-16"></div>
                <div class="h-4 bg-gray-100 rounded mx-auto w-24"></div>
              </div>
            ))}
          </div>
          <div class="bg-white rounded-lg shadow-lg p-6 mb-8 animate-pulse">
            <div class="h-6 bg-gray-200 rounded w-64 mb-4"></div>
            <div class="h-48 bg-gray-100 rounded"></div>
          </div>
          <div class="bg-white rounded-lg shadow-lg p-6 animate-pulse">
            <div class="h-6 bg-gray-200 rounded w-48 mb-4"></div>
            <div class="space-y-3">
              {[1, 2, 3, 4, 5].map(() => <div class="h-10 bg-gray-100 rounded"></div>)}
            </div>
          </div>
        </div>
      </LiveFeed>
    </div>
  </section>

  <!-- How to Interpret Results -->
  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Understanding Confidence Levels</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center p-6 rounded-lg bg-green-50 border-2 border-green-200">
          <div class="inline-block px-4 py-2 bg-green-100 text-green-800 rounded-full font-semibold mb-3">90-100%</div>
          <h3 class="font-semibold text-gray-900 mb-2">High Confidence</h3>
          <p class="text-sm text-gray-600">Very reliable identification. The AI is highly certain about this species.</p>
        </div>
        <div class="text-center p-6 rounded-lg bg-yellow-50 border-2 border-yellow-200">
          <div class="inline-block px-4 py-2 bg-yellow-100 text-yellow-800 rounded-full font-semibold mb-3">70-89%</div>
          <h3 class="font-semibold text-gray-900 mb-2">Medium Confidence</h3>
          <p class="text-sm text-gray-600">Good identification. The AI is reasonably certain, but similar species may exist.</p>
        </div>
        <div class="text-center p-6 rounded-lg bg-gray-50 border-2 border-gray-200">
          <div class="inline-block px-4 py-2 bg-gray-100 text-gray-800 rounded-full font-semibold mb-3">&lt;70%</div>
          <h3 class="font-semibold text-gray-900 mb-2">Lower Confidence</h3>
          <p class="text-sm text-gray-600">Possible identification. Audio quality or similar species may affect accuracy.</p>
        </div>
      </div>
    </div>
  </section>

  <DataUpdated generatedAt={birds.generatedAt} />
</Base>

<script>
  // Watchdog for the LiveFeed server island. If the island endpoint fails
  // (function error, misdeployed /_server-islands route), Astro's runtime
  // silently leaves the fallback skeleton in place and the refresh controls
  // never get their handlers (the script ships with the island payload).
  // This runs from the static shell: after 10s without the island, swap the
  // skeleton for an error state and make "Refresh Now" a full page reload.
  const WATCHDOG_MS = 10_000;

  const islandLoaded = () => document.getElementById("liveFeedRoot") !== null;

  if (!islandLoaded()) {
    let reloadHandler: (() => void) | null = null;

    const showErrorState = () => {
      const fallback = document.getElementById("liveFallback");
      if (!fallback) return;

      fallback.innerHTML = `
        <div class="bg-white rounded-lg shadow-lg p-16 text-center" data-live-error>
          <svg class="w-16 h-16 mx-auto mb-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
          <h2 class="text-2xl font-bold text-gray-800 mb-3">Live Data Couldn't Load</h2>
          <p class="text-gray-600 mb-6 max-w-md mx-auto">
            The live detection feed didn't respond. The rest of the site is unaffected —
            reload the page to try again, or check back shortly.
          </p>
          <button id="liveErrorReloadBtn" class="btn-primary px-6 py-3 rounded-lg">Reload Page</button>
        </div>
      `;

      document.getElementById("liveErrorReloadBtn")?.addEventListener("click", () => location.reload());

      const statusText = document.getElementById("statusText");
      if (statusText) {
        statusText.textContent = "Live data unavailable";
        statusText.className = "text-red-600";
      }

      // The island script never arrived, so "Refresh Now" has no handler —
      // make it reload the whole page instead.
      const refreshBtn = document.getElementById("refreshBtn");
      if (refreshBtn) {
        reloadHandler = () => location.reload();
        refreshBtn.addEventListener("click", reloadHandler);
      }
    };

    const timer = setTimeout(() => {
      if (!islandLoaded()) showErrorState();
    }, WATCHDOG_MS);

    // If the island arrives (even after the error state was shown, e.g. a
    // slow cold start), undo: island insertion removes the fallback div
    // itself; we just detach the reload handler and reset the status.
    const observer = new MutationObserver(() => {
      if (!islandLoaded()) return;
      clearTimeout(timer);
      observer.disconnect();
      if (reloadHandler) {
        const refreshBtn = document.getElementById("refreshBtn");
        refreshBtn?.removeEventListener("click", reloadHandler);
        reloadHandler = null;
        const statusText = document.getElementById("statusText");
        if (statusText) {
          statusText.textContent = "Ready";
          statusText.className = "text-gray-600";
        }
      }
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }
</script>
