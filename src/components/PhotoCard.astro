---
import type { Photo } from "../lib/api";
import { toMountainDate } from "../lib/datetime";
import { slugify } from "../lib/slug";

interface Props {
  photo: Photo;
}

const { photo } = Astro.props;
---

{photo.species && (
  <a
    href={`/species/${slugify(photo.species.common_name)}/`}
    class="block bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300 group"
  >
    <div class="aspect-square bg-gray-100">
      <img
        src={photo.variants.medium?.url}
        alt={photo.species.common_name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
    <div class="p-4">
      <h3 class="text-lg font-bold text-gray-900 mb-1">{photo.species.common_name}</h3>
      {photo.species.scientific_name && (
        <p class="text-sm text-gray-600 italic mb-2">{photo.species.scientific_name}</p>
      )}
      {photo.caption && <p class="text-sm text-gray-700 line-clamp-2">{photo.caption}</p>}
      {photo.taken_at && <p class="text-xs text-gray-500 mt-2">{toMountainDate(photo.taken_at)}</p>}
    </div>
  </a>
)}
