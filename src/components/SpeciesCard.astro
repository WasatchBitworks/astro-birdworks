---
import type { Photo, SpeciesCount } from "../lib/api";
import { toMountainTime } from "../lib/datetime";
import { slugify } from "../lib/slug";

interface Props {
  species: SpeciesCount;
  photo: Photo | null;
}

const { species, photo } = Astro.props;
const thumbnail = photo?.variants.thumbnail;
---

<a
  href={`/species/${slugify(species.common_name)}/`}
  class="block bg-white rounded-lg shadow-md hover:shadow-lg transition overflow-hidden group"
>
  <div class="p-6">
    <!-- Header with thumbnail and detection count -->
    <div class="flex items-start justify-between gap-4 mb-4">
      <div class="flex items-start gap-3 flex-1">
        {thumbnail ? (
          <div class="flex-shrink-0 w-16 h-16 bg-gray-100 rounded overflow-hidden">
            <img
              src={thumbnail.url}
              alt={species.common_name}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        ) : (
          <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-gray-100 to-gray-200 rounded flex items-center justify-center">
            <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
        )}

        <!-- Name -->
        <div class="flex-1 min-w-0">
          <h3 class="text-lg font-semibold text-gray-900 leading-tight">{species.common_name}</h3>
          <p class="text-sm text-gray-500 italic mt-0.5">{species.scientific_name}</p>
        </div>
      </div>

      <!-- Detection count badge -->
      <div class="flex-shrink-0 bg-blue-50 border border-blue-200 rounded px-2 py-1 text-center">
        <p class="text-sm font-bold text-blue-600">{species.detection_count ?? 0}</p>
        <p class="text-xs text-blue-500">detections</p>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 gap-4 text-sm mb-4">
      <div>
        <p class="text-gray-500">Best Confidence</p>
        <p class="font-medium text-gray-900">
          {species.max_confidence ? `${Math.round(species.max_confidence * 100)}%` : "—"}
        </p>
      </div>
      <div>
        <p class="text-gray-500">Avg Confidence</p>
        <p class="font-medium text-gray-900">
          {species.avg_confidence ? `${Math.round(species.avg_confidence * 100)}%` : "—"}
        </p>
      </div>
    </div>

    <!-- Last seen -->
    <div class="pt-4 border-t border-gray-200">
      <p class="text-xs text-gray-500">
        Last seen: {species.last_seen ? toMountainTime(species.last_seen) : "Unknown"}
      </p>
    </div>
  </div>
</a>
