---
interface Props {
  speciesSlug: string;
}

const { speciesSlug } = Astro.props;
---

<!-- Yearly Detection Presence Grid — client-rendered, GitHub-style activity calendar -->
<section id="presenceSection" class="mb-8" data-species-slug={speciesSlug}>
  <h2 class="text-2xl font-bold text-forest-green mb-2">Detection Activity</h2>
  <p class="text-sm text-gray-500 mb-4">Detected at least once per day (last 12 months)</p>

  <div id="presenceGridContainer" class="bg-white rounded-lg shadow-md p-4 overflow-x-auto">
    <!-- Loading state -->
    <div id="presenceLoading" class="text-center py-8">
      <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-leaf-green mx-auto mb-2"></div>
      <p class="text-sm text-gray-500">Loading activity data...</p>
    </div>

    <!-- Grid rendered here by the component script -->
    <div id="presenceGrid" class="hidden"></div>

    <!-- Empty state -->
    <div id="presenceEmpty" class="hidden text-center py-8">
      <svg class="w-12 h-12 mx-auto mb-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      <p class="text-gray-600">No detection data available for the last 12 months.</p>
    </div>
  </div>
</section>

<script>
  import { apiRoot } from "../../lib/client-api";

  const section = document.getElementById("presenceSection");
  const speciesSlug = section?.dataset.speciesSlug;
  const presenceLoading = document.getElementById("presenceLoading");
  const presenceGrid = document.getElementById("presenceGrid");
  const presenceEmpty = document.getElementById("presenceEmpty");

  if (speciesSlug && presenceGrid) {
    fetch(`${apiRoot()}/species/${speciesSlug}/presence?days=365`)
      .then((response) => {
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        return response.json();
      })
      .then((data) => renderPresenceGrid(data.dates || []))
      .catch((error) => {
        console.error("Error fetching presence data:", error);
        showPresenceError();
      });
  }

  function renderPresenceGrid(dates: string[]) {
    if (presenceLoading) presenceLoading.style.display = "none";

    if (!dates || dates.length === 0) {
      presenceEmpty?.classList.remove("hidden");
      return;
    }

    const dateSet = new Set(dates);

    // Build 365-day grid (rolling last 12 months)
    // Grid: 7 rows (Mon-Sun) × 53 columns (weeks), most recent week on the right
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const dayOfWeek = today.getDay();
    const mondayOffset = dayOfWeek === 0 ? -6 : 1 - dayOfWeek; // Sunday = 0
    const currentWeekMonday = new Date(today);
    currentWeekMonday.setDate(today.getDate() + mondayOffset);

    const startDate = new Date(currentWeekMonday);
    startDate.setDate(startDate.getDate() - 52 * 7);

    const gridHtml = document.createElement("div");
    gridHtml.className = "flex gap-1";

    const dayLabels = document.createElement("div");
    dayLabels.className = "flex flex-col gap-1 mr-2 text-xs text-gray-400";
    dayLabels.innerHTML = `
      <div class="h-3 leading-3">Mon</div>
      <div class="h-3 leading-3"></div>
      <div class="h-3 leading-3">Wed</div>
      <div class="h-3 leading-3"></div>
      <div class="h-3 leading-3">Fri</div>
      <div class="h-3 leading-3"></div>
      <div class="h-3 leading-3">Sun</div>
    `;
    gridHtml.appendChild(dayLabels);

    // Weeks container (reversed so newest data is on left)
    const weeksContainer = document.createElement("div");
    weeksContainer.className = "flex gap-1 flex-row-reverse";

    let currentDate = new Date(startDate);
    let weekCount = 0;
    const maxWeeks = 53;

    while (weekCount < maxWeeks && currentDate <= today) {
      const weekColumn = document.createElement("div");
      weekColumn.className = "flex flex-col gap-1";

      for (let dayIdx = 0; dayIdx < 7; dayIdx++) {
        const cellDate = new Date(currentDate);
        cellDate.setDate(currentDate.getDate() + dayIdx);

        const cell = document.createElement("div");
        cell.className = "w-3 h-3 rounded-sm";

        const isToday = cellDate.toDateString() === today.toDateString();

        // Monitoring began Dec 23, 2025 (local-timezone constructor avoids UTC offset issues)
        const monitoringBeganDate = new Date(2025, 11, 23);
        monitoringBeganDate.setHours(0, 0, 0, 0);
        const isMonitoringBegan = cellDate.toDateString() === monitoringBeganDate.toDateString();

        if (cellDate > today) {
          cell.className += " bg-gray-50";
        } else {
          const dateStr = formatDateISO(cellDate);
          const hasDetection = dateSet.has(dateStr);

          if (hasDetection) {
            cell.className += " bg-green-400 hover:bg-green-500";
          } else {
            cell.className += " bg-gray-100 hover:bg-gray-200";
          }

          if (isToday) cell.className += " ring-2 ring-gray-700";
          if (isMonitoringBegan) cell.className += " ring-2 ring-orange-500";

          cell.title = isMonitoringBegan
            ? "Dec 23, 2025 - Monitoring Began"
            : formatDateTooltip(cellDate, hasDetection);
        }

        weekColumn.appendChild(cell);
      }

      weeksContainer.appendChild(weekColumn);
      currentDate.setDate(currentDate.getDate() + 7);
      weekCount++;
    }

    gridHtml.appendChild(weeksContainer);

    // Month labels (below grid) - positioned at each month boundary
    const monthBar = document.createElement("div");
    monthBar.className = "flex gap-1 mt-1 text-xs text-gray-400";
    monthBar.style.marginLeft = "40px";

    const monthsContainer = document.createElement("div");
    monthsContainer.className = "relative";
    monthsContainer.style.width = `${weekCount * 16}px`;

    // Calculate month positions (go backwards from today to match reversed grid)
    let labelDate = new Date(today);
    let lastMonth = -1;
    const monthPositions: Array<{ month: string; weeksFromEnd: number }> = [];

    while (labelDate >= startDate) {
      const month = labelDate.getMonth();
      if (month !== lastMonth) {
        const weeksSinceStart = Math.floor(
          (labelDate.getTime() - startDate.getTime()) / (7 * 24 * 60 * 60 * 1000),
        );
        monthPositions.push({
          month: labelDate.toLocaleDateString("en-US", { month: "short" }),
          weeksFromEnd: weekCount - weeksSinceStart,
        });
        lastMonth = month;
      }
      labelDate.setDate(labelDate.getDate() - 7);
    }

    monthPositions.forEach((pos) => {
      const monthLabel = document.createElement("span");
      monthLabel.textContent = pos.month;
      monthLabel.className = "absolute text-xs text-gray-400";
      monthLabel.style.left = `${(pos.weeksFromEnd - 1) * 16}px`;
      monthsContainer.appendChild(monthLabel);
    });

    monthBar.appendChild(monthsContainer);

    const legend = document.createElement("div");
    legend.className = "flex flex-wrap items-center gap-2 mt-6 text-xs text-gray-500";
    legend.innerHTML = `
      <div class="w-3 h-3 rounded-sm bg-green-400"></div>
      <span>Detected</span>
      <span class="ml-3 text-gray-400">•</span>
      <div class="w-3 h-3 rounded-sm bg-gray-100 ring-2 ring-gray-700 ml-3"></div>
      <span>Today</span>
      <span class="ml-3 text-gray-400">•</span>
      <div class="w-3 h-3 rounded-sm bg-gray-100 ring-2 ring-orange-500 ml-3"></div>
      <span>Monitoring Began</span>
      <span class="ml-3 text-gray-400">•</span>
      <span class="ml-2">${dates.length} days in last year</span>
    `;

    presenceGrid!.innerHTML = "";
    presenceGrid!.appendChild(gridHtml);
    presenceGrid!.appendChild(monthBar);
    presenceGrid!.appendChild(legend);
    presenceGrid!.classList.remove("hidden");
  }

  function formatDateISO(date: Date): string {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, "0");
    const day = String(date.getDate()).padStart(2, "0");
    return `${year}-${month}-${day}`;
  }

  function formatDateTooltip(date: Date, hasDetection: boolean): string {
    const formatted = date.toLocaleDateString("en-US", {
      weekday: "short",
      month: "short",
      day: "numeric",
      year: "numeric",
    });
    return hasDetection ? `${formatted} - Detected` : `${formatted} - No detections`;
  }

  function showPresenceError() {
    if (presenceLoading) {
      presenceLoading.innerHTML = `
        <div class="text-center py-4">
          <svg class="w-8 h-8 mx-auto mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-sm text-gray-500">Unable to load activity data</p>
        </div>
      `;
    }
  }
</script>
